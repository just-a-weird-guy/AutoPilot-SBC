{
  "manifest_version": 3,
  "name": "AutopilotSBC | FC26 SBC Solver",
  "version": "1.7.1",
  "description": "automation tool for solving SBCs in the EA SPORTS FC Web App.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "AutopilotSBC",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["storage", "scripting"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["content-script.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start",
      "matches": [
        "https://www.ea.com/ea-sports-fc/ultimate-team/web-app/*",
        "https://www.ea.com/*/ea-sports-fc/ultimate-team/web-app/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page/ea-data-bridge.js",
        "data/changelog.json",
        "solver/solver.js",
        "solver/chemistry.js",
        "solver/constraint-compiler.js",
        "solver/worker.js",
        "solver/glpk.js",
        "solver/glpk.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
