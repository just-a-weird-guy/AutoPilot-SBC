{
  "manifest_version": 3,
  "name": "AutopilotSBC",
  "version": "0.1.0",
  "description": "Injects a page bridge to read EA FC web app data and logs to console.",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "js": ["content-script.js"],
      "all_frames": true,
      "match_about_blank": true,
      "run_at": "document_start",
      "matches": [
        "https://www.ea.com/ea-sports-fc/ultimate-team/web-app/*",
        "https://www.ea.com/*/ea-sports-fc/ultimate-team/web-app/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page/ea-data-bridge.js",
        "solver/solver.js",
        "solver/chemistry.js",
        "solver/constraint-compiler.js",
        "solver/worker.js",
        "solver/glpk.js",
        "solver/glpk.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
